{
  "name": "nextgen-bhajanavali",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @ngb/db exec prisma generate",
    "db:migrate": "pnpm --filter @ngb/db exec prisma migrate dev",
    "db:push": "pnpm --filter @ngb/db exec prisma db push",
    "db:seed": "pnpm --filter @ngb/db exec prisma db seed",
    "db:studio": "pnpm --filter @ngb/db exec prisma studio",
    "ingest": "pnpm --filter @ngb/tool-ingest start --",
    "ingest:list-adapters": "pnpm --filter @ngb/tool-ingest start -- list-adapters",
    "discover:source": "pnpm --filter @ngb/tool-ingest start -- discover",
    "crawl:source": "pnpm --filter @ngb/tool-ingest start -- crawl",
    "parse:source": "pnpm --filter @ngb/tool-ingest start -- parse",
    "sync:source": "pnpm --filter @ngb/tool-ingest start -- sync",
    "import:ingest": "pnpm --filter @ngb/tool-ingest start -- import"
  },
  "devDependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
