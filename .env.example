# =============================================================================
# Next Gen Bhajanavali — environment template (MVP / demo)
# Copy to:
#   - apps/web/.env.local     (Next.js — DATABASE_URL optional if API routes need DB)
#   - packages/db/.env        (Prisma CLI: migrate, seed, studio)
# Or keep one file and symlink both paths to it.
# =============================================================================

# --- Database (required for catalog pages, search, sitemap entity URLs) -----
# Local Postgres example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ngb_dev?schema=public"

# Supabase (Transaction pooler — use port 6543 + sslmode=require for serverless):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
#
# Direct connection (migrations / prisma migrate — often port 5432):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"

# --- Public site URL (required in production for canonical URLs, OG, sitemap) -
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Ingest / ops (optional) ------------------------------------------------
# Skip checksum dedup guard when you intentionally remap content (use sparingly):
# NGB_INGEST_SKIP_CHECKSUM_GUARD=1

# Override repo-relative path for config/sources/*.json:
# NGB_SOURCES_CONFIG_DIR=/absolute/path/to/config/sources
